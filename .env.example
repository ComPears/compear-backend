# Server
PORT=4000

# Comma-separated frontend origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8888,https://compears.shop

# Required to trigger POST /scrape/:store (send as x-api-key header)
SCRAPE_API_KEY=change-me-to-a-long-random-string

# Path to compears-data-wrangling (defaults to ../compears-data-wrangling)
# WRANGLING_PATH=/path/to/compears-data-wrangling

# Max products per store when seeding (0 = no limit)
# SEED_MAX_PRODUCTS=0

# Optional: OpenAI for AI normalization and promo interpretation
# OPENAI_API_KEY=sk-...
