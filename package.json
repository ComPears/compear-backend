{
  "name": "compears-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/data dist/data && mkdir -p dist/data/receipts dist/data/lists",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "scrape:ah": "ts-node src/scrapers/run-albert-heijn.ts",
    "seed": "ts-node src/scripts/seedFromWrangling.ts",
    "import-stores": "ts-node src/scripts/importStoreLocationsFromOsm.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
